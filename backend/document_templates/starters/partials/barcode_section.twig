{% if (document is defined and document.barcode_value) or barcode_value %}
<div class="barcode-section text-center">
  {{ barcode((document.barcode_value if document is defined else none) | default(barcode_value)) }}
  <div class="text-muted" style="font-size:8px;font-family:monospace;">{{ (document.barcode_value if document is defined else none) | default(barcode_value) }}</div>
</div>
{% endif %}
