# Vite dev server (browser-only helpers). NOT the API.

# Optional: stable QR / deep link base when it differs from window.location (e.g. http://192.168.0.83:5173).
VITE_PUBLIC_URL=

# --- API (FastAPI) ---

# Dev (recommended): leave EMPTY. Axios uses /api; Vite proxies to FastAPI on this machine (LAN + HTTPS OK).
# VITE_API_URL=

# Dev proxy target (read by vite.config.ts only; not exposed to import.meta.env).
# Default if unset: http://localhost:8010
# VITE_API_PROXY_TARGET=http://localhost:8010

# Production: HTTPS only (e.g. Railway). Must include /api path. Rebuild after change.
# VITE_API_URL=https://sasist-production.up.railway.app/api

# WMS: emulator skanera (drawer). Domyślnie włączony. Ustaw false, aby ukryć panel.
# Keyboard wedge (HID) działa dodatkowo w Vite DEV albo gdy ta flaga = true.
# VITE_ENABLE_DEV_SCANNER=true
# VITE_ENABLE_DEV_SCANNER=false
