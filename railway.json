{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "backend/**",
      "requirements.txt",
      "run_server.py",
      "nixpacks.toml",
      "railway.toml",
      "railway.json",
      "Procfile"
    ]
  },
  "deploy": {
    "startCommand": "python3 run_server.py",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE"
  }
}
